DATASET_YELP_PATH=/absolute/path/to/yelp_reviews.jsonl
DATASET_AMAZON_PATH=/absolute/path/to/amazon_reviews.jsonl
DATASET_GOODREADS_PATH=/absolute/path/to/goodreads_reviews.jsonl
DETERMINISTIC_MODE=false
PROFILE_CACHE_TTL_SECONDS=3600
PROFILE_CACHE_MAX_SIZE=1000
ENABLE_LLM=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Single vector store (used by Task B recommend and agent endpoints)
# Path to a pre-built vector store JSON produced by the ingestion CLI.
VECTOR_STORE_PATH=

# Per-domain vector stores for cross-domain retrieval (MultiVectorStoreService).
# Set any combination; only configured domains are queried.
VECTOR_STORE_PATH_YELP=
VECTOR_STORE_PATH_AMAZON=
VECTOR_STORE_PATH_GOODREADS=
