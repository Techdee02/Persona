# ── Dataset paths (only needed when running the ingestion CLI) ────────────────
DATASET_YELP_PATH=/absolute/path/to/yelp_reviews.json
DATASET_AMAZON_PATH=/absolute/path/to/amazon_reviews.jsonl
DATASET_GOODREADS_PATH=/absolute/path/to/goodreads_reviews.jsonl

# ── Profile cache ─────────────────────────────────────────────────────────────
DETERMINISTIC_MODE=false
PROFILE_CACHE_TTL_SECONDS=3600
PROFILE_CACHE_MAX_SIZE=1000

# ── LLM (OpenAI) ──────────────────────────────────────────────────────────────
ENABLE_LLM=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Vector store ──────────────────────────────────────────────────────────────
# Path where the vector store is saved/loaded on disk.
# On DigitalOcean this will be /data/yelp_vector_store.json (inside the Docker volume).
VECTOR_STORE_PATH=/data/yelp_vector_store.json

# Per-domain stores for cross-domain retrieval (leave empty if not used).
VECTOR_STORE_PATH_YELP=
VECTOR_STORE_PATH_AMAZON=
VECTOR_STORE_PATH_GOODREADS=

# ── DigitalOcean Spaces (vector store auto-download on first boot) ────────────
# The entrypoint script downloads the vector store from Spaces if VECTOR_STORE_PATH
# does not exist yet. Leave DO_SPACES_BUCKET empty to skip auto-download.
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=
DO_SPACES_KEY=
DO_SPACES_SECRET=
# Object key of the vector store file inside the bucket (default: yelp_vector_store.json)
DO_SPACES_VECTOR_STORE_KEY=yelp_vector_store.json

# ── CORS (Vercel frontend) ────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to allow all (*) — fine for dev.
# Production example: ALLOWED_ORIGINS=https://yourapp.vercel.app,https://www.yourdomain.com
ALLOWED_ORIGINS=
